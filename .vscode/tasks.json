{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure (Debug)",
      "type": "shell",
      "command": "cmake -G Ninja -S . -B build",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "CMake Build (Debug)",
      "type": "shell",
      "command": "cmake --build --preset Debug",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "dependsOn": "CMake Configure (Debug)"
    },
    {
      "label": "Run OVGE",
      "type": "shell",
      "command": "${workspaceFolder}/out/build/Debug/OVGE.exe",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "dependsOn": "CMake Build (Debug)"
    }
  ]
}